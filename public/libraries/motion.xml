<?xml version="1.0" encoding="UTF-8"?>
<Library>
  <Category name="MOTION">

    <!-- ═══════════════════════════════════════════════════════════════════
         ADMINISTRATIVE
         PLCopen TC2 Part 1 v2.0
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- MC_Power — Enable / Disable axis power stage -->
    <Block type="MC_Power" description="Enable / disable axis power stage" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"           type="AXIS_REF" />
        <Variable name="Enable"         type="BOOL"  default="FALSE" />
        <Variable name="EnablePositive" type="BOOL"  default="TRUE"  />
        <Variable name="EnableNegative" type="BOOL"  default="TRUE"  />
      </Inputs>
      <Outputs>
        <Variable name="Status"  type="BOOL" />
        <Variable name="Valid"   type="BOOL" />
        <Variable name="Error"   type="BOOL" />
        <Variable name="ErrorID" type="WORD" />
      </Outputs>
    </Block>

    <!-- MC_Reset — Clear axis fault, return to Standstill -->
    <Block type="MC_Reset" description="Reset axis from ErrorStop state" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"    type="AXIS_REF" />
        <Variable name="Execute" type="BOOL" default="FALSE" />
      </Inputs>
      <Outputs>
        <Variable name="Done"    type="BOOL" />
        <Variable name="Busy"    type="BOOL" />
        <Variable name="Error"   type="BOOL" />
        <Variable name="ErrorID" type="WORD" />
      </Outputs>
    </Block>

    <!-- MC_SetOverride — Scale velocity / acceleration / jerk at runtime -->
    <Block type="MC_SetOverride" description="Scale velocity, acceleration and jerk factors" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"       type="AXIS_REF" />
        <Variable name="Enable"     type="BOOL" default="FALSE" />
        <Variable name="VelFactor"  type="REAL" default="1.0" />
        <Variable name="AccFactor"  type="REAL" default="1.0" />
        <Variable name="JerkFactor" type="REAL" default="1.0" />
      </Inputs>
      <Outputs>
        <Variable name="Enabled"  type="BOOL" />
        <Variable name="Busy"     type="BOOL" />
        <Variable name="Error"    type="BOOL" />
        <Variable name="ErrorID"  type="WORD" />
      </Outputs>
    </Block>

    <!-- ═══════════════════════════════════════════════════════════════════
         STOP / HALT
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- MC_Stop — Highest-priority controlled stop; holds axis in Stopping -->
    <Block type="MC_Stop" description="Controlled emergency stop (highest priority)" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"         type="AXIS_REF" />
        <Variable name="Execute"      type="BOOL" default="FALSE" />
        <Variable name="Deceleration" type="REAL" default="1000.0" />
        <Variable name="Jerk"         type="REAL" default="0.0" />
      </Inputs>
      <Outputs>
        <Variable name="Done"           type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

    <!-- MC_Halt — Controlled stop to Standstill (lower priority than MC_Stop) -->
    <Block type="MC_Halt" description="Controlled stop to Standstill" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"         type="AXIS_REF" />
        <Variable name="Execute"      type="BOOL" default="FALSE" />
        <Variable name="Deceleration" type="REAL" default="500.0" />
        <Variable name="Jerk"         type="REAL" default="0.0" />
        <Variable name="BufferMode"   type="DINT" default="0" />
      </Inputs>
      <Outputs>
        <Variable name="Done"           type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="Active"         type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

    <!-- ═══════════════════════════════════════════════════════════════════
         HOMING
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- MC_Home — Execute homing sequence, set axis position reference -->
    <Block type="MC_Home" description="Execute homing sequence and set position reference" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"        type="AXIS_REF" />
        <Variable name="Execute"     type="BOOL" default="FALSE" />
        <Variable name="Position"    type="REAL" default="0.0" />
        <Variable name="HomingMode"  type="DINT" default="0" />
      </Inputs>
      <Outputs>
        <Variable name="Done"           type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="Active"         type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

    <!-- ═══════════════════════════════════════════════════════════════════
         POINT-TO-POINT MOTION
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- MC_MoveAbsolute — Move to absolute target position -->
    <Block type="MC_MoveAbsolute" description="Move to absolute target position with S-curve profile" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"             type="AXIS_REF" />
        <Variable name="Execute"          type="BOOL" default="FALSE" />
        <Variable name="ContinuousUpdate" type="BOOL" default="FALSE" />
        <Variable name="Position"         type="REAL" default="0.0" />
        <Variable name="Velocity"     type="REAL" default="100.0" />
        <Variable name="Acceleration" type="REAL" default="500.0" />
        <Variable name="Deceleration" type="REAL" default="500.0" />
        <Variable name="Jerk"         type="REAL" default="0.0" />
        <Variable name="BufferMode"   type="DINT" default="0" />
      </Inputs>
      <Outputs>
        <Variable name="Done"           type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="Active"         type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

    <!-- MC_MoveRelative — Move by relative distance -->
    <Block type="MC_MoveRelative" description="Move by relative distance with S-curve profile" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"             type="AXIS_REF" />
        <Variable name="Execute"          type="BOOL" default="FALSE" />
        <Variable name="ContinuousUpdate" type="BOOL" default="FALSE" />
        <Variable name="Distance"         type="REAL" default="0.0" />
        <Variable name="Velocity"     type="REAL" default="100.0" />
        <Variable name="Acceleration" type="REAL" default="500.0" />
        <Variable name="Deceleration" type="REAL" default="500.0" />
        <Variable name="Jerk"         type="REAL" default="0.0" />
        <Variable name="BufferMode"   type="DINT" default="0" />
      </Inputs>
      <Outputs>
        <Variable name="Done"           type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="Active"         type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

    <!-- MC_MoveAdditive — Add incremental move on top of current motion -->
    <Block type="MC_MoveAdditive" description="Add incremental distance to current motion target" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"             type="AXIS_REF" />
        <Variable name="Execute"          type="BOOL" default="FALSE" />
        <Variable name="ContinuousUpdate" type="BOOL" default="FALSE" />
        <Variable name="Distance"         type="REAL" default="0.0" />
        <Variable name="Velocity"     type="REAL" default="100.0" />
        <Variable name="Acceleration" type="REAL" default="500.0" />
        <Variable name="Deceleration" type="REAL" default="500.0" />
        <Variable name="Jerk"         type="REAL" default="0.0" />
        <Variable name="BufferMode"   type="DINT" default="0" />
      </Inputs>
      <Outputs>
        <Variable name="Done"           type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="Active"         type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

    <!-- ═══════════════════════════════════════════════════════════════════
         VELOCITY MOTION
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- MC_MoveVelocity — Continuous velocity motion (no position target) -->
    <!-- Direction: 1=Positive, -1=Negative, 0=CurrentDirection, 2=Fastest -->
    <Block type="MC_MoveVelocity" description="Continuous velocity motion (no position target)" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"             type="AXIS_REF" />
        <Variable name="Execute"          type="BOOL" default="FALSE" />
        <Variable name="ContinuousUpdate" type="BOOL" default="FALSE" />
        <Variable name="Velocity"         type="REAL" default="100.0" />
        <Variable name="Acceleration" type="REAL" default="500.0" />
        <Variable name="Deceleration" type="REAL" default="500.0" />
        <Variable name="Jerk"         type="REAL" default="0.0" />
        <Variable name="Direction"    type="DINT" default="1" />
        <Variable name="BufferMode"   type="DINT" default="0" />
      </Inputs>
      <Outputs>
        <Variable name="InVelocity"     type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="Active"         type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

    <!-- MC_MoveSuperimposed — Superimposed relative move on top of running motion -->
    <Block type="MC_MoveSuperimposed" description="Superimposed relative move on top of running motion" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"                type="AXIS_REF" />
        <Variable name="Execute"             type="BOOL" default="FALSE" />
        <Variable name="Distance"            type="REAL" default="0.0" />
        <Variable name="VelocityDiff"        type="REAL" default="10.0" />
        <Variable name="AccelerationDiff"    type="REAL" default="100.0" />
        <Variable name="DecelerationDiff"    type="REAL" default="100.0" />
        <Variable name="JerkDiff"            type="REAL" default="0.0" />
      </Inputs>
      <Outputs>
        <Variable name="Done"           type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="Active"         type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

    <!-- MC_HaltSuperimposed — Cancel superimposed move -->
    <Block type="MC_HaltSuperimposed" description="Cancel superimposed move, return to base motion" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"         type="AXIS_REF" />
        <Variable name="Execute"      type="BOOL" default="FALSE" />
        <Variable name="Deceleration" type="REAL" default="500.0" />
        <Variable name="Jerk"         type="REAL" default="0.0" />
      </Inputs>
      <Outputs>
        <Variable name="Done"           type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="Active"         type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

    <!-- ═══════════════════════════════════════════════════════════════════
         READ / DIAGNOSTIC
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- MC_ReadActualPosition — Read current actual position -->
    <Block type="MC_ReadActualPosition" description="Read axis actual position" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"   type="AXIS_REF" />
        <Variable name="Enable" type="BOOL" default="FALSE" />
      </Inputs>
      <Outputs>
        <Variable name="Valid"    type="BOOL" />
        <Variable name="Busy"     type="BOOL" />
        <Variable name="Error"    type="BOOL" />
        <Variable name="ErrorID"  type="WORD" />
        <Variable name="Position" type="REAL" />
      </Outputs>
    </Block>

    <!-- MC_ReadActualVelocity — Read current actual velocity -->
    <Block type="MC_ReadActualVelocity" description="Read axis actual velocity" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"   type="AXIS_REF" />
        <Variable name="Enable" type="BOOL" default="FALSE" />
      </Inputs>
      <Outputs>
        <Variable name="Valid"     type="BOOL" />
        <Variable name="Busy"      type="BOOL" />
        <Variable name="Error"     type="BOOL" />
        <Variable name="ErrorID"   type="WORD" />
        <Variable name="Velocity"  type="REAL" />
      </Outputs>
    </Block>

    <!-- MC_ReadActualTorque — Read current actual torque -->
    <Block type="MC_ReadActualTorque" description="Read axis actual torque (% of rated)" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"   type="AXIS_REF" />
        <Variable name="Enable" type="BOOL" default="FALSE" />
      </Inputs>
      <Outputs>
        <Variable name="Valid"    type="BOOL" />
        <Variable name="Busy"     type="BOOL" />
        <Variable name="Error"    type="BOOL" />
        <Variable name="ErrorID"  type="WORD" />
        <Variable name="Torque"   type="REAL" />
      </Outputs>
    </Block>

    <!-- MC_ReadStatus — Read axis PLCopen state diagram status flags -->
    <Block type="MC_ReadStatus" description="Read axis state diagram status flags" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"   type="AXIS_REF" />
        <Variable name="Enable" type="BOOL" default="FALSE" />
      </Inputs>
      <Outputs>
        <Variable name="Valid"              type="BOOL" />
        <Variable name="Busy"               type="BOOL" />
        <Variable name="Error"              type="BOOL" />
        <Variable name="ErrorID"            type="WORD" />
        <Variable name="ErrorStop"          type="BOOL" />
        <Variable name="Disabled"           type="BOOL" />
        <Variable name="Stopping"           type="BOOL" />
        <Variable name="Homing"             type="BOOL" />
        <Variable name="Standstill"         type="BOOL" />
        <Variable name="DiscreteMotion"     type="BOOL" />
        <Variable name="ContinuousMotion"   type="BOOL" />
        <Variable name="SynchronizedMotion" type="BOOL" />
      </Outputs>
    </Block>

    <!-- MC_ReadMotionState — Read current motion dynamics -->
    <Block type="MC_ReadMotionState" description="Read axis motion dynamics (accel, decel, direction)" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"   type="AXIS_REF" />
        <Variable name="Enable" type="BOOL" default="FALSE" />
        <Variable name="Source" type="DINT" default="0" />
      </Inputs>
      <Outputs>
        <Variable name="Valid"              type="BOOL" />
        <Variable name="Busy"               type="BOOL" />
        <Variable name="Error"              type="BOOL" />
        <Variable name="ErrorID"            type="WORD" />
        <Variable name="ConstantVelocity"   type="BOOL" />
        <Variable name="Accelerating"       type="BOOL" />
        <Variable name="Decelerating"       type="BOOL" />
        <Variable name="DirectionPositive"  type="BOOL" />
        <Variable name="DirectionNegative"  type="BOOL" />
      </Outputs>
    </Block>

    <!-- MC_ReadAxisInfo — Read comprehensive axis information -->
    <Block type="MC_ReadAxisInfo" description="Read axis info (homed, limits, simulation, power)" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"   type="AXIS_REF" />
        <Variable name="Enable" type="BOOL" default="FALSE" />
      </Inputs>
      <Outputs>
        <Variable name="Valid"              type="BOOL" />
        <Variable name="Busy"               type="BOOL" />
        <Variable name="Error"              type="BOOL" />
        <Variable name="ErrorID"            type="WORD" />
        <Variable name="HomeAbsSwitch"      type="BOOL" />
        <Variable name="LimitSwitchPos"     type="BOOL" />
        <Variable name="LimitSwitchNeg"     type="BOOL" />
        <Variable name="Simulation"         type="BOOL" />
        <Variable name="CommunicationReady" type="BOOL" />
        <Variable name="ReadyForPowerOn"    type="BOOL" />
        <Variable name="PowerOn"            type="BOOL" />
        <Variable name="IsHomed"            type="BOOL" />
        <Variable name="AxisWarning"        type="BOOL" />
      </Outputs>
    </Block>

    <!-- MC_ReadAxisError — Read axis-level error code -->
    <Block type="MC_ReadAxisError" description="Read axis error code" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"   type="AXIS_REF" />
        <Variable name="Enable" type="BOOL" default="FALSE" />
      </Inputs>
      <Outputs>
        <Variable name="Valid"       type="BOOL" />
        <Variable name="Busy"        type="BOOL" />
        <Variable name="Error"       type="BOOL" />
        <Variable name="ErrorID"     type="WORD" />
        <Variable name="AxisErrorID" type="WORD" />
      </Outputs>
    </Block>

    <!-- ═══════════════════════════════════════════════════════════════════
         PARAMETER READ / WRITE
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- MC_ReadParameter — Read numeric axis parameter by number -->
    <Block type="MC_ReadParameter" description="Read numeric axis parameter by number" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"            type="AXIS_REF" />
        <Variable name="Enable"          type="BOOL" default="FALSE" />
        <Variable name="ParameterNumber" type="INT"  default="0" />
      </Inputs>
      <Outputs>
        <Variable name="Valid"    type="BOOL" />
        <Variable name="Busy"     type="BOOL" />
        <Variable name="Error"    type="BOOL" />
        <Variable name="ErrorID"  type="WORD" />
        <Variable name="Value"    type="REAL" />
      </Outputs>
    </Block>

    <!-- MC_ReadBoolParameter — Read boolean axis parameter by number -->
    <Block type="MC_ReadBoolParameter" description="Read boolean axis parameter by number" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"            type="AXIS_REF" />
        <Variable name="Enable"          type="BOOL" default="FALSE" />
        <Variable name="ParameterNumber" type="INT"  default="0" />
      </Inputs>
      <Outputs>
        <Variable name="Valid"    type="BOOL" />
        <Variable name="Busy"     type="BOOL" />
        <Variable name="Error"    type="BOOL" />
        <Variable name="ErrorID"  type="WORD" />
        <Variable name="Value"    type="BOOL" />
      </Outputs>
    </Block>

    <!-- MC_WriteParameter — Write numeric axis parameter by number -->
    <Block type="MC_WriteParameter" description="Write numeric axis parameter by number" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"            type="AXIS_REF" />
        <Variable name="Execute"         type="BOOL" default="FALSE" />
        <Variable name="ParameterNumber" type="INT"  default="0" />
        <Variable name="Value"           type="REAL" default="0.0" />
      </Inputs>
      <Outputs>
        <Variable name="Done"    type="BOOL" />
        <Variable name="Busy"    type="BOOL" />
        <Variable name="Error"   type="BOOL" />
        <Variable name="ErrorID" type="WORD" />
      </Outputs>
    </Block>

    <!-- MC_WriteBoolParameter — Write boolean axis parameter by number -->
    <Block type="MC_WriteBoolParameter" description="Write boolean axis parameter by number" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"            type="AXIS_REF" />
        <Variable name="Execute"         type="BOOL" default="FALSE" />
        <Variable name="ParameterNumber" type="INT"  default="0" />
        <Variable name="Value"           type="BOOL" default="FALSE" />
      </Inputs>
      <Outputs>
        <Variable name="Done"    type="BOOL" />
        <Variable name="Busy"    type="BOOL" />
        <Variable name="Error"   type="BOOL" />
        <Variable name="ErrorID" type="WORD" />
      </Outputs>
    </Block>

    <!-- ═══════════════════════════════════════════════════════════════════
         SET POSITION
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- MC_SetPosition — Set / shift axis position reference -->
    <Block type="MC_SetPosition" description="Set or shift axis position reference value" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"     type="AXIS_REF" />
        <Variable name="Execute"  type="BOOL" default="FALSE" />
        <Variable name="Position" type="REAL" default="0.0" />
        <Variable name="Relative" type="BOOL" default="FALSE" />
      </Inputs>
      <Outputs>
        <Variable name="Done"    type="BOOL" />
        <Variable name="Busy"    type="BOOL" />
        <Variable name="Error"   type="BOOL" />
        <Variable name="ErrorID" type="WORD" />
      </Outputs>
    </Block>

    <!-- ═══════════════════════════════════════════════════════════════════
         CONTINUOUS MOTION
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- MC_MoveContinuousAbsolute — Move to absolute position with non-zero end velocity -->
    <Block type="MC_MoveContinuousAbsolute" description="Move to absolute position with non-zero end velocity" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"             type="AXIS_REF" />
        <Variable name="Execute"          type="BOOL" default="FALSE" />
        <Variable name="ContinuousUpdate" type="BOOL" default="FALSE" />
        <Variable name="Position"         type="REAL" default="0.0" />
        <Variable name="EndVelocity"      type="REAL" default="0.0" />
        <Variable name="Velocity"         type="REAL" default="100.0" />
        <Variable name="Acceleration"     type="REAL" default="500.0" />
        <Variable name="Deceleration"     type="REAL" default="500.0" />
        <Variable name="Jerk"             type="REAL" default="0.0" />
        <Variable name="Direction"        type="DINT" default="1" />
        <Variable name="BufferMode"       type="DINT" default="0" />
      </Inputs>
      <Outputs>
        <Variable name="InEndVelocity"  type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="Active"         type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

    <!-- MC_MoveContinuousRelative — Move by relative distance with non-zero end velocity -->
    <Block type="MC_MoveContinuousRelative" description="Move by relative distance with non-zero end velocity" class="FunctionBlock">
      <Inputs>
        <Variable name="Axis"             type="AXIS_REF" />
        <Variable name="Execute"          type="BOOL" default="FALSE" />
        <Variable name="ContinuousUpdate" type="BOOL" default="FALSE" />
        <Variable name="Distance"         type="REAL" default="0.0" />
        <Variable name="EndVelocity"      type="REAL" default="0.0" />
        <Variable name="Velocity"         type="REAL" default="100.0" />
        <Variable name="Acceleration"     type="REAL" default="500.0" />
        <Variable name="Deceleration"     type="REAL" default="500.0" />
        <Variable name="Jerk"             type="REAL" default="0.0" />
        <Variable name="BufferMode"       type="DINT" default="0" />
      </Inputs>
      <Outputs>
        <Variable name="InEndVelocity"  type="BOOL" />
        <Variable name="Busy"           type="BOOL" />
        <Variable name="Active"         type="BOOL" />
        <Variable name="CommandAborted" type="BOOL" />
        <Variable name="Error"          type="BOOL" />
        <Variable name="ErrorID"        type="WORD" />
      </Outputs>
    </Block>

  </Category>
</Library>
